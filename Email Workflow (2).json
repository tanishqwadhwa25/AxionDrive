    {
      "parameters": {
        "jsCode": "const html = $json.body.html;\nconst csv = $json.body.csv || '';\nconst email = $json.body.email;\n\nconst htmlBinary = Buffer.from(html, 'utf8').toString('base64');\nconst htmlFilename = `axiondrive_dashboard_${Date.now()}.html`;\n\nconst result = {\n  json: { email, htmlFilename },\n  binary: {\n    htmlFile: {\n      data: htmlBinary,\n      mimeType: 'text/html',\n      fileName: htmlFilename\n    }\n  }\n};\n\nif (csv && csv.trim()) {\n  const csvBinary = Buffer.from(csv, 'utf8').toString('base64');\n  const csvFilename = `axiondrive_data_${Date.now()}.csv`;\n  result.json.csvFilename = csvFilename;\n  result.binary.csvFile = {\n    data: csvBinary,\n    mimeType: 'text/csv',\n    fileName: csvFilename\n  };\n}\n\nreturn [result];"
      },
