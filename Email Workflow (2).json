        "subject": "AxionDrive Analytics Report",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n</head>\n<body style=\"margin:0;padding:0;background:#0a0a0f;font-family:'DM Sans',Arial,sans-serif;\">\n  <div style=\"max-width:600px;margin:0 auto;padding:32px 16px;\">\n    \n    <!-- Header -->\n    <div style=\"background:#12121a;border-radius:16px;padding:32px;margin-bottom:16px;border:1px solid rgba(255,255,255,0.06);\">\n      <div style=\"font-size:36px;font-weight:900;letter-spacing:2px;color:#e8ff47;\">\n        AXIONDRIVE\n      </div>\n      <div style=\"font-size:11px;color:#6b6b80;letter-spacing:3px;text-transform:uppercase;margin-top:4px;\">\n        Intelligence in Motion\n      </div>\n    </div>\n\n    <!-- Main Card -->\n    <div style=\"background:#12121a;border-radius:16px;padding:32px;margin-bottom:16px;border:1px solid rgba(255,255,255,0.06);\">\n      <div style=\"font-size:22px;font-weight:700;color:#f0f0f0;margin-bottom:8px;\">\n        Your Analytics Report is Ready 📊\n      </div>\n      <div style=\"font-size:14px;color:#6b6b80;margin-bottom:24px;line-height:1.6;\">\n        Your AxionDrive report has been generated and is attached to this email.\n      </div>\n      <!-- Divider -->\n      <div style=\"border-top:1px solid rgba(255,255,255,0.06);margin-bottom:24px;\"></div>\n      <!-- Attachments -->\n      <div style=\"font-size:11px;color:#6b6b80;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;\">\n        Attachments\n      </div>\n      <div style=\"background:#1a1a26;border-radius:10px;padding:14px 18px;margin-bottom:10px;display:flex;align-items:center;border:1px solid rgba(232,255,71,0.15);\">\n        <span style=\"font-size:20px;margin-right:12px;\">📄</span>\n        <div>\n          <div style=\"color:#e8ff47;font-size:13px;font-weight:600;\">Dashboard Report</div>\n          <div style=\"color:#6b6b80;font-size:11px;\">Open in browser to view interactive charts</div>\n        </div>\n      </div>\n      <div style=\"background:#1a1a26;border-radius:10px;padding:14px 18px;display:flex;align-items:center;border:1px solid rgba(71,200,255,0.15);\">\n        <span style=\"font-size:20px;margin-right:12px;\">📊</span>\n        <div>\n          <div style=\"color:#47c8ff;font-size:13px;font-weight:600;\">Cleaned CSV Data</div>\n          <div style=\"color:#6b6b80;font-size:11px;\">Open in Excel or Google Sheets</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Footer -->\n    <div style=\"background:#12121a;border-radius:16px;padding:20px 32px;border:1px solid rgba(255,255,255,0.06);\">\n      <div style=\"font-size:11px;color:#6b6b80;margin-bottom:4px;\">\n        Generated on {{ new Date().toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) }}\n      </div>\n      <div style=\"font-size:11px;color:#6b6b80;\">\n        Sent automatically via <span style=\"color:#e8ff47;\">n8n</span>\n      </div>\n    </div>\n\n  </div>\n</body>\n</html>",
